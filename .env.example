# --- Required ---

# Get this from @BotFather on Telegram. Keep it secret.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Comma-separated list of Telegram usernames allowed to talk to the bot.
# At least one of ALLOWED_USERS or ALLOWED_USER_IDS must be set, otherwise
# the bot is open to ANYONE who finds the bot handle.
ALLOWED_USERS=your_telegram_username

# --- Optional ---

# Comma-separated list of Telegram numeric user IDs (resilient to username changes).
# ALLOWED_USER_IDS=123456789,987654321

# Bearer token required by the /webhook endpoint.
# Generate with: openssl rand -hex 32
# WEBHOOK_SECRET=

# HTTPS URL of the Mini App dashboard (webapp/index.html served via Cloudflare Tunnel,
# ngrok, etc). Without this, the "Dashboard" button is hidden.
# WEBAPP_URL=https://example.com/app

# Default Claude model override. Examples: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5
# CLAUDE_MODEL=

# Absolute path to the `claude` CLI. Auto-detected from $PATH; only set if needed.
# CLAUDE_BIN=/opt/homebrew/bin/claude

# Path to a JSON file with extra Docker health checks. See README → "User Context".
# HEALTH_CHECKS_FILE=

# --- Discord adapter (optional) ---
# Create an app at https://discord.com/developers/applications
# Enable the Message Content privileged intent. Install discord.py:
#   pip install 'discord.py>=2.4'
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USER_IDS=123456789012345678,234567890123456789

# --- Slack adapter (optional) ---
# Create an app at https://api.slack.com/apps with Socket Mode enabled.
# Install slack-bolt:
#   pip install 'slack-bolt[async]>=1.18'
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_ALLOWED_USER_IDS=U01ABCDEFGH

# --- Web (browser chat) ---
# WEB_HOST=127.0.0.1
# WEB_PORT=8765
# WEB_AUTH_TOKEN=                  # auto-generated by the setup wizard
# WEB_DISABLED=1                   # set to 1 to disable the browser chat
